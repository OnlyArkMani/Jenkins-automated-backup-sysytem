
pipeline {
    agent any

    parameters {
        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Git branch to build'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target deployment environment'
        )
    }

    environment {
        PYTHON = 'C:\\Users\\arkma\\AppData\\Local\\Programs\\Python\\Python311\\python.exe'
        PIP    = 'C:\\Users\\arkma\\AppData\\Local\\Programs\\Python\\Python311\\Scripts\\pip.exe'
        FLAKE8 = 'C:\\Users\\arkma\\AppData\\Local\\Programs\\Python\\Python311\\Scripts\\flake8.exe'
        PYTEST = 'C:\\Users\\arkma\\AppData\\Local\\Programs\\Python\\Python311\\Scripts\\pytest.exe'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    stages {

        // ── Stage 1: Checkout ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "==> Checking out branch: ${params.BRANCH}"
                checkout scm
                echo "Checkout complete."
            }
        }

        // ── Stage 2: Lint ─────────────────────────────────────────────────────
        stage('Lint') {
            steps {
                echo "==> Installing flake8 and running linter"
                bat """
                    "${PIP}" install flake8 --quiet
                    "${FLAKE8}" src/app.py --max-line-length=100 --exclude=__pycache__
                    echo Lint passed!
                """
            }
        }

        // ── Stage 3: Test ─────────────────────────────────────────────────────
        stage('Test') {
            steps {
                echo "==> Installing dependencies and running pytest"
                bat """
                    "${PIP}" install pytest pytest-cov flask requests --quiet
                    "${PYTEST}" src/tests/test_app.py -v --tb=short --junitxml=src/test-results.xml
                """
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'src/test-results.xml'
                }
            }
        }

        // ── Stage 4: Build Docker Image ───────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                echo "==> Building Docker image"
                bat """
                    docker build -f infrastructure/docker/Dockerfile -t devopsproject/weather-dashboard:%BUILD_NUMBER% -t devopsproject/weather-dashboard:latest .
                    echo Docker image built successfully!
                """
            }
        }

        // ── Stage 5: Deploy ───────────────────────────────────────────────────
        stage('Deploy') {
            steps {
                echo "==> Deploying to ${params.ENVIRONMENT}"
                bat """
                    docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env up -d
                    echo App deployed! Visit http://localhost:5000
                """
            }
        }

    }

    post {
        success {
            echo "Pipeline PASSED - Build #${env.BUILD_NUMBER} succeeded."
        }
        failure {
            echo "Pipeline FAILED - Check the logs above."
        }
        always {
            echo "Pipeline finished."
        }
    }
}