pipeline {
    agent any

    parameters {
        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Git branch to build'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target deployment environment'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip test stage (use only for hotfixes)'
        )
    }

    environment {
        APP_NAME      = 'weather-dashboard'
        IMAGE_NAME    = "devopsproject/${APP_NAME}"
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
        FULL_IMAGE    = "${IMAGE_NAME}:${IMAGE_TAG}"
        LATEST_IMAGE  = "${IMAGE_NAME}:latest"

        OPENWEATHER_API_KEY = credentials('openweather-api-key')
        DOCKER_HUB_CREDS    = credentials('dockerhub-credentials')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        ansiColor('xterm')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                echo "==> Checking out branch: ${params.BRANCH}"
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${params.BRANCH}"]],
                    userRemoteConfigs: [[url: 'https://github.com/YOUR_USERNAME/devopsprojectweatherdashboard.git']]
                ])
                sh 'echo "Commit: $(git log -1 --oneline)"'
            }
        }

        stage('Lint') {
            steps {
                echo "==> Running flake8 linter"
                dir('src') {
                    sh '''
                        pip install flake8 --quiet --break-system-packages || true
                        flake8 app.py \
                            --max-line-length=100 \
                            --exclude=__pycache__ \
                            --format="%(path)s:%(row)d:%(col)d: %(code)s %(text)s"
                    '''
                }
            }
            post {
                failure {
                    echo "Lint failed — fix code style errors before merging."
                }
            }
        }

        stage('Test') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                echo "==> Running pytest with coverage"
                dir('src') {
                    sh '''
                        pip install pytest pytest-cov flask requests --quiet --break-system-packages || true
                        pytest tests/test_app.py \
                            -v \
                            --tb=short \
                            --cov=. \
                            --cov-report=xml:coverage.xml \
                            --cov-report=term-missing \
                            --junitxml=test-results.xml
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'src/test-results.xml'
                    publishCoverage(
                        adapters: [coberturaAdapter('src/coverage.xml')],
                        sourceFileResolver: sourceFiles('NEVER_STORE')
                    )
                }
                failure {
                    echo "Tests failed — check the test report above."
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "==> Building Docker image: ${FULL_IMAGE}"
                sh '''
                    docker build \
                        -f infrastructure/docker/Dockerfile \
                        -t ${FULL_IMAGE} \
                        -t ${LATEST_IMAGE} \
                        .
                '''
                sh 'docker images | grep ${IMAGE_NAME}'
            }
            post {
                success {
                    echo "Docker image built successfully: ${FULL_IMAGE}"
                }
            }
        }

        stage('Security Scan') {
            steps {
                echo "==> Scanning image for vulnerabilities with Trivy"
                sh '''
                    if ! command -v trivy &> /dev/null; then
                        wget -qO- https://github.com/aquasecurity/trivy/releases/download/v0.50.0/trivy_0.50.0_Linux-64bit.tar.gz | tar xz -C /tmp
                        sudo mv /tmp/trivy /usr/local/bin/ || mv /tmp/trivy ./trivy
                        TRIVY_CMD=./trivy
                    else
                        TRIVY_CMD=trivy
                    fi

                    $TRIVY_CMD image \
                        --severity HIGH,CRITICAL \
                        --exit-code 0 \
                        --format table \
                        ${FULL_IMAGE}
                '''
            }
        }

        stage('Deploy — Dev') {
            when {
                expression { params.ENVIRONMENT == 'dev' }
            }
            steps {
                echo "==> Deploying to Dev (Docker Compose)"
                sh '''
                    export OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}
                    docker-compose \
                        -f infrastructure/docker/docker-compose.yml \
                        up -d --build
                    echo "App running at http://localhost:5000"
                '''
            }
        }

        stage('Deploy — Staging') {
            when {
                expression { params.ENVIRONMENT == 'staging' }
            }
            steps {
                echo "==> Deploying to Staging (Kubernetes / minikube)"
                sh '''
                    sed -i "s|IMAGE_TAG_PLACEHOLDER|${IMAGE_TAG}|g" \
                        infrastructure/kubernetes/deployment.yaml

                    kubectl apply -f infrastructure/kubernetes/configmap.yaml
                    kubectl apply -f infrastructure/kubernetes/deployment.yaml
                    kubectl apply -f infrastructure/kubernetes/service.yaml

                    kubectl rollout status deployment/${APP_NAME} --timeout=120s
                    kubectl get pods,svc | grep ${APP_NAME}
                '''
            }
        }

        stage('Deploy — Production') {
            when {
                expression { params.ENVIRONMENT == 'prod' }
            }
            steps {
                input message: "Deploy build #${env.BUILD_NUMBER} to PRODUCTION?", ok: 'Deploy'
                echo "==> Deploying to Production"
                sh '''
                    kubectl set image deployment/${APP_NAME} \
                        ${APP_NAME}=${FULL_IMAGE} \
                        --record

                    kubectl rollout status deployment/${APP_NAME} --timeout=180s
                '''
            }
        }

    }

    post {

        success {
            echo """
            ╔══════════════════════════════════════╗
            ║     Pipeline PASSED                ║
            ║   Build : #${env.BUILD_NUMBER}
            ║   Branch: ${params.BRANCH}
            ║   Env   : ${params.ENVIRONMENT}
            ╚══════════════════════════════════════╝
            """
            emailext(
                subject: " [${APP_NAME}] Build #${env.BUILD_NUMBER} Passed",
                body: """
                    Pipeline completed successfully.

                    Branch      : ${params.BRANCH}
                    Environment : ${params.ENVIRONMENT}
                    Image       : ${FULL_IMAGE}
                    Build URL   : ${env.BUILD_URL}
                """,
                to: 'your-email@university.edu'
            )
        }

        failure {
            echo " Pipeline FAILED — check logs at ${env.BUILD_URL}"
            emailext(
                subject: " [${APP_NAME}] Build #${env.BUILD_NUMBER} FAILED",
                body: """
                    Pipeline failed at stage: ${env.STAGE_NAME}

                    Branch    : ${params.BRANCH}
                    Build URL : ${env.BUILD_URL}consoleText
                """,
                to: 'your-email@university.edu'
            )
        }

        always {
            echo "==> Cleaning up dangling Docker images"
            sh 'docker image prune -f || true'
            cleanWs()
        }

    }

}