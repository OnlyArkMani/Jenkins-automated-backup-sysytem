pipeline {
    agent any

    parameters {
        string(
            name: 'BRANCH',
            defaultValue: 'main',
            description: 'Git branch to build'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target deployment environment'
        )
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    stages {

        // ── Stage 1: Checkout ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "==> Checking out branch: ${params.BRANCH}"
                checkout scm
                echo "Checkout complete."
            }
        }

        // ── Stage 2: Lint ─────────────────────────────────────────────────────
        stage('Lint') {
            steps {
                echo "==> Running flake8 linter"
                bat '''
                    cd src
                    pip install flake8 --quiet
                    flake8 app.py --max-line-length=100 --exclude=__pycache__
                '''
            }
        }

        // ── Stage 3: Test ─────────────────────────────────────────────────────
        stage('Test') {
            steps {
                echo "==> Running pytest"
                bat '''
                    cd src
                    pip install pytest pytest-cov flask requests --quiet
                    pytest tests/test_app.py -v --tb=short --junitxml=test-results.xml
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'src/test-results.xml'
                }
            }
        }

        // ── Stage 4: Build Docker Image ───────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                echo "==> Building Docker image"
                bat 'docker build -f infrastructure/docker/Dockerfile -t devopsproject/weather-dashboard:%BUILD_NUMBER% -t devopsproject/weather-dashboard:latest .'
            }
        }

        // ── Stage 5: Deploy ───────────────────────────────────────────────────
        stage('Deploy') {
            steps {
                echo "==> Deploying to ${params.ENVIRONMENT}"
                bat 'docker-compose -f infrastructure/docker/docker-compose.yml --env-file .env up -d'
                echo "App deployed! Visit http://localhost:5000"
            }
        }

    }

    post {
        success {
            echo "Pipeline PASSED - Build #${env.BUILD_NUMBER} succeeded."
        }
        failure {
            echo "Pipeline FAILED - Check the logs above."
        }
        always {
            echo "Pipeline finished."
        }
    }
}